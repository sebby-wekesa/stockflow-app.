generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  ADMIN      // Can see reports, manage BOM, and release orders
  MANAGER    // Can approve and manage production orders
  OPERATOR   // Can only see their department queue and log weights
  SALES      // Can view sales-related data
  PACKAGING  // Can handle packaging operations
  WAREHOUSE  // Can only log raw material intake
}

enum ProductionStatus {
  PENDING       // Waiting for Manager Review 
  APPROVED      // Released to production [cite: 46]
  IN_PRODUCTION // Moving through departments [cite: 47]
  COMPLETED     // Finished goods added to stock [cite: 48]
  REJECTED      // Sent back by Manager [cite: 51]
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model User {
  id              String     @id @default(cuid())
  email           String     @unique
  password        String
  name            String?
  role            Role       @default(OPERATOR)
  department      String?    // e.g., "Cutting", "Forging" (for Operators)
  organizationId  String?
  organization    Organization? @relation(fields: [organizationId], references: [id])
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  stageLogs       StageLog[]
  saleOrders      SaleOrder[]
}

model Design {
  id               String            @id @default(cuid())
  name             String            // e.g., Hex Bolt M12 [cite: 67]
  code             String            @unique // e.g., HB-M12 [cite: 74]
  description      String?
  targetDimensions String?           // Stores specs like 12mm x 70mm [cite: 71]
  targetWeight     Float?            // Estimated yield kg per unit [cite: 135]
  // New Phase 2 Fields
  rawMaterialId    String?           // Links to the specific rod needed (e.g., M12 High Tensile)
  kgPerUnit        Float             @default(0.0) // The BOM consumption rate
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  stages           Stage[]
  productionOrders ProductionOrder[]
  saleOrders       SaleOrder[]
}

model Stage {
  id          String     @id @default(cuid())
  name        String     // e.g., Cutting, Forging, Threading [cite: 65]
  department  String     // The department responsible for this stage [cite: 65]
  sequence    Int        // Order of operations [cite: 68]
  designId    String
  design      Design     @relation(fields: [designId], references: [id], onDelete: Cascade)
  stageLogs   StageLog[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([designId, sequence])
}

model ProductionOrder {
  id            String           @id @default(cuid())
  orderNumber   String           @unique // e.g., PO-0040 [cite: 93]
  designId      String
  design        Design           @relation(fields: [designId], references: [id])
  quantity      Int              @default(1)
  targetKg      Float            // Total initial weight (In) [cite: 55]
  status        ProductionStatus @default(PENDING)
  priority      Priority         @default(MEDIUM)

  // Handoff Tracking
  currentStage  Int              @default(1) // Current sequence number
  currentDept   String?          // Current department queue (e.g., "Cutting") [cite: 99]

  assignedTo    String?
  approvedBy    String?
  approvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  logs          StageLog[]
  finishedGoods FinishedGood[]

  @@index([status, createdAt])
  @@index([currentDept, status])
}

model StageLog {
  id          String          @id @default(cuid())
  orderId     String
  order       ProductionOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stageId     String?
  stage       Stage?          @relation(fields: [stageId], references: [id])
  stageName   String
  sequence    Int

  // KG Traceability: Enforces In = Out + Scrap [cite: 55, 78]
  kgIn        Float           // Weight received from previous stage [cite: 77]
  kgOut       Float           // Weight passed forward [cite: 77]
  kgScrap     Float           // Weight lost [cite: 77]
  scrapReason String?         // e.g., "Off-cuts", "Scale", "Swarf" [cite: 65, 153]
  department  String?         // Department responsible for this stage log [new field]

  operatorId  String
  operator    User            @relation(fields: [operatorId], references: [id])
  notes       String?
  completedAt DateTime        @default(now())
}

model Organization {
  id        String     @id @default(cuid())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  users     User[]
  branches  Branch[]
}

model Branch {
  id             String       @id @default(cuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Supplier {
  id             String                @id @default(cuid())
  name           String
  contactInfo    String?
  rawMaterials   RawMaterial[]
  receipts       RawMaterialReceipt[]
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
}

model Customer {
  id        String     @id @default(cuid())
  name      String
  contactInfo String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  saleOrders SaleOrder[]
}

model Item {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?  // e.g., "Raw Material", "Finished Good"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RawMaterial {
  id            String                @id @default(cuid())
  materialName  String                // e.g., "High-Tensile Steel"
  diameter      String                // e.g., "M12"
  availableKg   Float                 @default(0) // Available for reservation
  reservedKg    Float                 @default(0) // Reserved for production
  supplierId    String?
  supplier      Supplier?             @relation(fields: [supplierId], references: [id])
  receipts      RawMaterialReceipt[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model RawMaterialReceipt {
  id            String       @id @default(cuid())
  rawMaterialId String
  rawMaterial   RawMaterial  @relation(fields: [rawMaterialId], references: [id], onDelete: Cascade)
  quantity      Float        // kg received
  supplierId    String?
  supplier      Supplier?    @relation(fields: [supplierId], references: [id])
  receivedAt    DateTime     @default(now())
}

model FinishedGood {
  id                String          @id @default(cuid())
  designId          String
  design            Design          @relation(fields: [designId], references: [id])
  productionOrderId String?
  productionOrder   ProductionOrder? @relation(fields: [productionOrderId], references: [id])
  quantity          Int
  location          String?         // branch or warehouse
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
}

enum SaleStatus {
  PENDING     // Waiting for packaging
  PACKAGING   // Being prepared
  PACKAGED    // Ready for pickup/shipping
  SHIPPED     // Sent to customer
  CANCELLED
}

model SaleOrder {
  id             String     @id @default(cuid())
  designId       String
  design         Design     @relation(fields: [designId], references: [id])
  quantity       Int        // Units requested
  customerId     String?
  customer       Customer?  @relation(fields: [customerId], references: [id])
  status         SaleStatus @default(PENDING)
  salesRepId     String     // User who created the order
  salesRep       User       @relation(fields: [salesRepId], references: [id])
  notes          String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
}

model StockTransaction {
  id             String   @id @default(cuid())
  itemType       String   // 'raw' or 'finished'
  itemId         String   // rawMaterialId or finishedGoodId
  transactionType String  // 'receipt', 'consumption', 'sale', etc.
  quantity       Float
  reason         String?
  performedBy    String   // userId
  createdAt      DateTime @default(now())
}